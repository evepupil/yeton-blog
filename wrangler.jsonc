{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hero-ui-blog",
  "compatibility_date": "2026-07-14",
  "pages_build_output_dir": "./out",
  "ai": {
    "binding": "AI",
  },
  "d1_databases": [
    {
      "binding": "AI_RATE_LIMIT_DB",
      "database_name": "yeton-blog-ai-rate-limit",
      "database_id": "9fe3c93e-3875-42de-b53a-3e514681ba6f",
      "migrations_dir": "migrations/ai-search",
    },
  ],
}
