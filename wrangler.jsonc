{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hero-ui-blog",
  "compatibility_date": "2026-07-14",
  "pages_build_output_dir": "./out",
  "ai": {
    "binding": "AI",
  },
  "d1_databases": [
    {
      "binding": "APP_DB",
