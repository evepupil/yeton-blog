{
  "name": "hero-ui-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": "22.14.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm redirects:build && pnpm cloudflare:check && pnpm content:check && pnpm search:build && tsx scripts/prepare-next-build.ts && next build && pnpm functions:build && pnpm site:check",
    "preview": "wrangler pages dev out",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "content:check": "tsx scripts/validate-content.ts",
    "content:migrate-legacy": "tsx scripts/migrate-legacy-content.ts",
    "content:migrate-legacy-books": "tsx scripts/migrate-legacy-books.ts",
    "sync-notion": "tsx scripts/sync-notion.ts",
    "sync-notion:new": "tsx scripts/sync-notion.ts --mode=new-only",
    "sync-notion:append": "tsx scripts/sync-notion.ts --mode=append",
    "sync-friends": "tsx scripts/sync-notion-friends.ts",
    "sync-content": "pnpm sync-notion && pnpm sync-friends",
    "ai-search:migrate": "wrangler d1 migrations apply yeton-blog-ai-rate-limit --remote",
    "functions:build": "wrangler pages functions build functions --outdir out/_worker.js --minify",
    "redirects:build": "tsx scripts/generate-redirects.ts",
    "search:build": "tsx scripts/generate-search-index.ts",
    "site:check": "tsx scripts/check-static-output.ts",
    "cloudflare:check": "tsx scripts/validate-cloudflare-build.ts",
    "smoke:deployment": "tsx scripts/smoke-deployment.ts",
    "test": "pnpm test:unit && pnpm test:prototype",
    "test:unit": "vitest run",
    "test:prototype": "node --test tests/content.test.cjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fontsource-variable/noto-serif-sc": "5.2.10",
    "@heroui/react": "3.2.2",
    "@notionhq/client": "3.1.3",
    "dotenv": "17.2.1",
    "fast-xml-parser": "5.10.0",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "lucide-react": "1.24.0",
    "mdast-util-to-string": "4.0.0",
    "minisearch": "7.2.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "notion-to-md": "3.1.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "parse5": "8.0.1",
    "prettier": "3.9.5",
    "serve": "14.2.6",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
