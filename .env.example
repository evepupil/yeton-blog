# Used for canonical URLs, RSS and social metadata during static builds.
NEXT_PUBLIC_SITE_URL=https://example.com

# Server-side only. Configure these as GitHub Actions secrets.
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_FRIEND_LINK_DATABASE_ID=
WEREAD_API_KEY=

# Optional. Defaults to the Status value used by the reference database.
NOTION_PUBLISHED_STATUS=Published
